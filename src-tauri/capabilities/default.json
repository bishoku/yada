{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "allow-create-workspace",
    "allow-load-workspace",
    "allow-get-recent-workspaces",
    "allow-save-recent-workspaces",
    "allow-save-workspace",
    "allow-load-preferences",
    "allow-save-preferences",
    "allow-load-diagram",
    "allow-save-diagram",
    "allow-save-text-file",
    "allow-read-text-file",
    "allow-delete-file",
    "allow-list-json-files-in-dir",
    "allow-get-global-components-dir",
    "fs:default",
    "fs:allow-write-file"
  ]
}